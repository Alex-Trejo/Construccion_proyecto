###############################################################################
# SGC / FacturLink — Variables de PRODUCCIÓN (plantilla)
#
#   1. cp .env.production.example .env
#   2. Completar TODOS los valores con secretos NUEVOS (no reutilizar los de dev).
#   3. NUNCA commitear el .env real.
#
# Diferencias clave vs desarrollo:
#   - Hostnames = nombres de servicio del compose (no 127.0.0.1).
#   - URLs públicas en https:// (a través de Caddy).
#   - CORS_ORIGIN fijado al dominio real.
#   - NODE_ENV=production.
###############################################################################

# ── Imágenes GHCR (CI/CD) ────────────────────────────────────────────────────
# El compose de prod tira las imágenes de ghcr.io/${GHCR_OWNER}/sgc-*:${IMAGE_TAG}.
GHCR_OWNER=alex-trejo                         # tu usuario/org de GitHub en minúsculas
IMAGE_TAG=latest                             # o un SHA concreto para fijar versión

# ── General / Dominios ───────────────────────────────────────────────────────
# 1 dominio, 3 subdominios → todos apuntan a la Elastic IP (wildcard *. o 3 A).
NODE_ENV=production
APP_DOMAIN=facturlink.xyz                    # la app
AUTH_DOMAIN=auth.facturlink.xyz              # Keycloak (SSO)
GRAFANA_DOMAIN=grafana.facturlink.xyz        # observabilidad

# ── Imágenes GHCR (para `docker compose pull` en el CD) ──────────────────────
GHCR_OWNER=alex-trejo                         # owner del repo en minúsculas
IMAGE_TAG=latest                             # o un SHA para fijar versión

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=sgc-postgres                   # nombre de servicio del compose
POSTGRES_PORT=5432
POSTGRES_USER=sgc_user
POSTGRES_PASSWORD=__CAMBIAR_password_fuerte__
POSTGRES_DB=sgc_db

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=__CAMBIAR_admin_fuerte__
KEYCLOAK_REALM=sgc-realm
KC_DB_NAME=keycloak                        # BD dedicada de Keycloak (persistencia en Postgres)
KEYCLOAK_CLIENT_ID=sgc-frontend
KEYCLOAK_CLIENT_SECRET=__CAMBIAR_secret_del_client__
KEYCLOAK_ISSUER_URL=https://auth.facturlink.xyz/realms/sgc-realm
# NextAuth (frontend) — mismo issuer:
KEYCLOAK_ISSUER=https://auth.facturlink.xyz/realms/sgc-realm

# ── API Gateway ──────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
# CORS: dominio(s) permitido(s), separados por coma. OBLIGATORIO en producción.
CORS_ORIGIN=https://facturlink.xyz

# ── ms-core / ms-sync (TCP interno entre contenedores) ───────────────────────
MS_CORE_TCP_HOST=sgc-ms-core
MS_CORE_TCP_PORT=3001
MS_CORE_HTTP_PORT=3010
MS_SYNC_TCP_HOST=sgc-ms-sync
MS_SYNC_TCP_PORT=3002
MS_SYNC_HTTP_PORT=3012
XSD_SCHEMAS_PATH=./infrastructure/xsd

# ── OCR (OpenAI Vision) ──────────────────────────────────────────────────────
OPENAI_API_KEY=__CAMBIAR_rotar_la_expuesta__
OPENAI_OCR_MODEL=gpt-4o-mini

# ── Cifrado de secretos IMAP (AES-256-GCM) ───────────────────────────────────
# 64 hex. DEBE ser idéntica en ms-core y ms-sync. Al rotarla, los usuarios
# deben volver a guardar su configuración IMAP.
ENCRYPTION_KEY=__CAMBIAR_64_hex__

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=__CAMBIAR__
MINIO_ROOT_PASSWORD=__CAMBIAR_min_8_chars__
MINIO_ENDPOINT=http://sgc-minio:9000
MINIO_BUCKET_NAME=sgc-documents

# ── ms-sync IMAP (opcional; las credenciales reales van cifradas por usuario) ─
SYNC_INTERVAL_MINUTES=5

# ── Observabilidad (Prometheus / Loki / Grafana) ─────────────────────────────
PROMETHEUS_PORT=9090
LOKI_PORT=3100
LOKI_URL=http://loki:3100
GRAFANA_PORT=3050
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__CAMBIAR_grafana_fuerte__

# ── Frontend (NextAuth + público) ────────────────────────────────────────────
NEXTAUTH_URL=https://facturlink.xyz
NEXTAUTH_SECRET=__CAMBIAR_openssl_rand_base64_32__
# NEXT_PUBLIC_* son de BUILD (se embeben en el bundle):
NEXT_PUBLIC_API_GATEWAY_URL=https://facturlink.xyz/api/v1
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.facturlink.xyz
NEXT_PUBLIC_KEYCLOAK_REALM=sgc-realm
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=sgc-frontend
