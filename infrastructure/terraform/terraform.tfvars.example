# Copia este archivo a terraform.tfvars y completa tus valores.
#   cp terraform.tfvars.example terraform.tfvars

aws_region     = "us-east-1"
instance_type  = "t3.large"       # o "t3.medium" (4GB) si ajustas la observabilidad
volume_size_gb = 30

# Tu clave pública SSH (créala con: ssh-keygen -t ed25519)
ssh_public_key_path = "~/.ssh/id_ed25519.pub"

# Tu IP pública /32 (mírala en https://ifconfig.me). Restringe el SSH.
admin_ssh_cidr = "TU_IP_PUBLICA/32"

# Repo a clonar en la instancia
repo_url = "https://github.com/Alex-Trejo/Construccion_proyecto.git"

# Dominios (1 dominio + 2 subdominios)
app_domain     = "facturlink.xyz"
auth_domain    = "auth.facturlink.xyz"
grafana_domain = "grafana.facturlink.xyz"

# DNS: si usas Route 53 pon true + el zone_id; si usas otro registrador, deja false.
manage_route53  = false
route53_zone_id = ""
