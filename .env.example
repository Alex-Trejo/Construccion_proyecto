###############################################################################
# SGC - Sistema de Gestión de Comprobantes
# Variables de Entorno — Archivo de Referencia
#
# ⚠️  INSTRUCCIONES:
#   1. Copiar este archivo:  cp .env.example .env
#   2. Completar TODOS los valores. No dejar ninguno vacío.
#   3. NUNCA commitear el archivo .env al repositorio.
#
# ⚠️  REGLA FAIL-FAST:
#   Si falta cualquier variable, la aplicación CRASHEARÁ al arrancar.
#   No existen valores de fallback. Todo es obligatorio.
###############################################################################

# ─────────────────────────────────────────────────────────────────────────────
# GENERAL
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=                                 # development | production | test

# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_HOST=                            # Ej: localhost o sgc-postgres (en Docker)
POSTGRES_PORT=                            # Ej: 5432
POSTGRES_USER=                            # Usuario de la base de datos
POSTGRES_PASSWORD=                        # Contraseña de la base de datos
POSTGRES_DB=                              # Nombre de la base de datos

# ─────────────────────────────────────────────────────────────────────────────
# KEYCLOAK — Identity and Access Management
# ─────────────────────────────────────────────────────────────────────────────
KEYCLOAK_PORT=                            # Puerto expuesto (Ej: 8080)
KEYCLOAK_ADMIN_USER=                      # Usuario administrador de Keycloak
KEYCLOAK_ADMIN_PASSWORD=                  # Contraseña administrador de Keycloak
KEYCLOAK_REALM=                           # Nombre del Realm (Ej: sgc-realm)
KEYCLOAK_CLIENT_ID=                       # Client ID para el frontend/gateway
KEYCLOAK_CLIENT_SECRET=                   # Client Secret
KEYCLOAK_ISSUER_URL=                      # Ej: http://localhost:8080/realms/sgc-realm

# ─────────────────────────────────────────────────────────────────────────────
# MINIO — Object Storage S3-compatible
# ─────────────────────────────────────────────────────────────────────────────
MINIO_API_PORT=                           # Puerto de la API S3 (Ej: 9000)
MINIO_CONSOLE_PORT=                       # Puerto de la consola web (Ej: 9001)
MINIO_ROOT_USER=                          # Usuario root de MinIO
MINIO_ROOT_PASSWORD=                      # Contraseña root de MinIO (mín. 8 chars)
MINIO_ENDPOINT=                           # Ej: http://localhost:9000
MINIO_BUCKET_NAME=                        # Nombre del bucket (Ej: sgc-documents)

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILIDAD — Stack PLG (Prometheus, Loki, Grafana)
# ─────────────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=                          # Puerto de Prometheus (Ej: 9090)
LOKI_PORT=                                # Puerto de Loki (Ej: 3100)
# URL a la que las apps ENVÍAN sus logs (winston-loki).
#   - Local (apps en el host):   http://127.0.0.1:3100
#   - Docker (apps en contenedor): http://loki:3100   ← OBLIGATORIO en el deploy
LOKI_URL=                                 # Ej local: http://127.0.0.1:3100 · Ej Docker: http://loki:3100
GRAFANA_PORT=                             # Puerto de Grafana (Ej: 3050)
GRAFANA_ADMIN_USER=                       # Usuario admin de Grafana
GRAFANA_ADMIN_PASSWORD=                   # Contraseña admin de Grafana

# ─────────────────────────────────────────────────────────────────────────────
# API GATEWAY (NestJS)
# ─────────────────────────────────────────────────────────────────────────────
API_GATEWAY_PORT=                         # Puerto HTTP del gateway (Ej: 3000)
CORS_ORIGIN=                              # (Opcional) Orígenes permitidos coma-separados. Vacío = permitir todo (solo dev). En prod: https://tudominio.com

# ─────────────────────────────────────────────────────────────────────────────
# MS-CORE — Microservicio de Negocio (NestJS)
# ─────────────────────────────────────────────────────────────────────────────
MS_CORE_TCP_HOST=                         # Host TCP (Ej: localhost o ms-core)
MS_CORE_TCP_PORT=                         # Puerto TCP (Ej: 3001)
MS_CORE_HTTP_PORT=                        # Puerto HTTP para healthcheck (Ej: 3010)
XSD_SCHEMAS_PATH=                         # (Opcional) Path a XSD del SRI (Ej: ./infrastructure/xsd)

# ── OCR (OpenAI Vision) — comprobantes físicos ───────────────────────────────
OPENAI_API_KEY=                           # API key de OpenAI (Ej: sk-...)
OPENAI_OCR_MODEL=                         # Modelo de visión (Ej: gpt-4o-mini)

# ── Cifrado de secretos (contraseñas IMAP) ───────────────────────────────────
# 64 caracteres hex (= 32 bytes). DEBE ser idéntica en ms-core y ms-sync.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# MS-SYNC — Worker IMAP (NestJS)
# ─────────────────────────────────────────────────────────────────────────────
MS_SYNC_TCP_HOST=                         # Host TCP (Ej: localhost o ms-sync)
MS_SYNC_TCP_PORT=                         # Puerto TCP (Ej: 3002)
MS_SYNC_HTTP_PORT=                        # Puerto HTTP interno para /metrics (Ej: 3012)
# IMAP_* es LEGADO/opcional: las credenciales reales se guardan CIFRADAS por
# usuario vía POST /user/imap-config; ms-sync las descifra con ENCRYPTION_KEY.
IMAP_HOST=                                # (Opcional) Servidor IMAP (Ej: imap.gmail.com)
IMAP_PORT=                                # (Opcional) Puerto IMAP (Ej: 993)
IMAP_USER=                                # (Opcional) Correo del bot (Ej: bot@empresa.com)
IMAP_PASSWORD=                            # (Opcional) App Password de Gmail
IMAP_TLS=                                 # (Opcional) true | false
SYNC_INTERVAL_MINUTES=                    # Intervalo de polling IMAP en minutos (Ej: 5)
ENCRYPTION_KEY=                           # MISMA clave que ms-core (64 hex) — descifra passwords IMAP

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=                      # URL del API Gateway (Ej: http://localhost:3000)
NEXT_PUBLIC_KEYCLOAK_URL=                 # URL de Keycloak (Ej: http://localhost:8080)
NEXT_PUBLIC_KEYCLOAK_REALM=               # Realm de Keycloak
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=           # Client ID público

# ─────────────────────────────────────────────────────────────────────────────
# SONARCLOUD — CI/CD (Solo para GitHub Actions)
# ─────────────────────────────────────────────────────────────────────────────
SONAR_TOKEN=                              # Token de autenticación SonarCloud
SONAR_ORGANIZATION=                       # Organización en SonarCloud
SONAR_PROJECT_KEY=                        # Clave del proyecto en SonarCloud
