{
  "name": "@sgc/ms-sync",
  "version": "0.0.1",
  "private": true,
  "description": "SGC — Worker IMAP (NestJS). Extrae adjuntos XML/PDF de bandejas de correo y los envía a ms-core vía TCP.",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:cov": "jest --coverage",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@sgc/shared": "workspace:*",
    "imapflow": "^1.0.160",
    "joi": "^17.13.0",
    "mailparser": "^3.7.0",
    "nest-winston": "^1.9.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.13.0",
    "winston-loki": "^6.1.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/jest": "^30.0.0",
    "@types/mailparser": "^3.4.5",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
